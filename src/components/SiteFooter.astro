---
import LanguageSwitcher from './LanguageSwitcher.astro'
import { useTranslations } from '../i18n/utils'

interface Props {
  locale?: string
  currentPath?: string
  countryCode?: string
}

const { locale = 'en', currentPath = '/', countryCode } = Astro.props
const t = useTranslations(locale)
