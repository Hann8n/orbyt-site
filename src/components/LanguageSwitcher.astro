---
import { SUPPORTED_LOCALES, DEFAULT_LOCALE, LOCALE_LABELS } from '../i18n/utils'

interface Props {
  currentLocale: string
  currentPath?: string
}

const { currentLocale, currentPath = '/' } = Astro.props
const allLocales = [DEFAULT_LOCALE, ...SUPPORTED_LOCALES]

const currentLabel = LOCALE_LABELS[currentLocale] ?? currentLocale
---

<div class="lang-switcher">
  <span class="lang-icon" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" style="display:block;flex-shrink:0">
      <path d="M11.08 2.045c-1.874.165-3.723.904-5.28 2.109-.437.339-1.307 1.209-1.646 1.646-1.8 2.326-2.505 5.195-1.976 8.046.29 1.566.959 3.04 1.976 4.354.339.437 1.209 1.307 1.646 1.646 2.441 1.889 5.453 2.566 8.44 1.895 2.487-.559 4.752-2.144 6.145-4.301.806-1.247 1.283-2.527 1.521-4.08.098-.641.098-2.079 0-2.72-.285-1.858-.936-3.388-2.06-4.84-.339-.437-1.209-1.307-1.646-1.646-2.067-1.599-4.554-2.336-7.12-2.109m1.345 2.068c.599.31 1.046 1.356 1.294 3.027.101.683.196 1.67.164 1.707-.147.171-3.619.171-3.766 0-.032-.037.063-1.024.164-1.707.274-1.845.761-2.87 1.479-3.105.154-.051.493-.011.665.078M8.8 4.714c0 .018-.037.14-.082.27-.227.656-.554 2.514-.558 3.176-.002.252-.024.257-.483.097-.761-.264-2.117-.892-2.117-.98 0-.071.496-.641.886-1.018A7.26 7.26 0 0 1 8.3 4.912c.454-.237.5-.256.5-.198m6.811.151a7.509 7.509 0 0 1 1.943 1.394c.385.372.886.947.886 1.016 0 .042-.866.486-1.32.677-.209.089-.568.226-.797.305-.459.16-.481.155-.482-.099-.001-.2-.15-1.389-.226-1.798a11.97 11.97 0 0 0-.333-1.376c-.085-.245-.097-.304-.061-.304a5.4 5.4 0 0 1 .39.185M4.662 9.077c.062.06 1.21.623 1.598.784.198.082.674.253 1.057.38l.697.232-.005 1.273c-.003.701.007 1.604.023 2.007.015.404.023.739.017.745-.041.041-1.301-.368-2.049-.664-.586-.233-1.852-.852-1.928-.943-.085-.103-.07-1.597.022-2.145.107-.639.42-1.706.501-1.706.016 0 .046.017.067.037m14.851.173a8.02 8.02 0 0 1 .478 3.021c-.019.553-.024.584-.115.654-.162.124-1.348.699-1.876.909-.746.296-2.008.705-2.049.664-.006-.006.002-.341.017-.745.016-.403.026-1.306.023-2.007l-.005-1.273.697-.232a20.45 20.45 0 0 0 1.057-.38c.386-.159 1.535-.723 1.598-.784.068-.066.095-.04.175.173M11 10.96c.83.063 1.855.039 2.776-.065l.236-.027-.026 1.816c-.028 1.978-.041 2.184-.141 2.213a10.34 10.34 0 0 1-.725.067c-.899.065-2.926.003-3.021-.092-.045-.045-.096-1.492-.097-2.767L10 10.871l.25.026c.138.014.475.042.75.063m-5.349 4.882c.623.238 1.355.465 2.055.637l.526.129.027.226c.085.695.279 1.624.447 2.139.056.171.093.321.082.332-.061.061-1.165-.58-1.688-.979a10.805 10.805 0 0 1-1.311-1.286c-.373-.461-.949-1.372-.949-1.499 0-.012.067.007.15.042.082.036.38.152.661.259m13.396-.056c-.319.629-.873 1.356-1.493 1.955-.459.444-.728.66-1.234.989-.372.241-1.076.607-1.108.575-.011-.011.026-.161.082-.332.167-.507.353-1.409.447-2.158l.025-.206.607-.15a20.184 20.184 0 0 0 2.327-.751c.242-.098.446-.173.453-.167.007.006-.041.116-.106.245m-7.507 1.199c.486.014 1.117.006 1.497-.02.361-.024.661-.04.666-.035.019.02-.105.663-.205 1.063-.253 1.01-.619 1.654-1.078 1.899-.116.062-.231.085-.42.085-.688 0-1.177-.667-1.516-2.069a11.478 11.478 0 0 1-.144-.668 2.58 2.58 0 0 0-.048-.256c-.02-.07-.005-.074.193-.05.118.014.593.037 1.055.051" fill="currentColor" fill-rule="evenodd"/>
    </svg>
  </span>
  <span class="lang-code">{currentLabel}</span>
  <select
    class="lang-select"
    aria-label="Select language"
    onchange="orbytSwitchLang(this.value)"
  >
    {allLocales.map((locale) => (
      <option value={locale} selected={locale === currentLocale}>
        {LOCALE_LABELS[locale]}
      </option>
    ))}
  </select>
</div>

<script is:inline define:vars={{ SUPPORTED_LOCALES, DEFAULT_LOCALE, currentPath }}>
  window.orbytSwitchLang = function (locale) {
    document.cookie = `orbyt-locale=${locale};max-age=31536000;path=/;samesite=lax`

    let path = currentPath
    for (const l of SUPPORTED_LOCALES) {
      if (path === `/${l}` || path.startsWith(`/${l}/`)) {
        path = path.slice(l.length + 1) || '/'
        break
      }
    }

    const dest = locale === DEFAULT_LOCALE
      ? (path || '/')
      : `/${locale}${path === '/' ? '/' : path}`

    window.location.href = dest
  }
</script>

<style>
  .lang-switcher {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    cursor: pointer;
    color: var(--orbyt-neutral-300);
    transition: color 0.15s ease;
    text-decoration: none;
    line-height: 1;
  }

  .lang-switcher:hover {
    color: var(--orbyt-white);
  }

  .lang-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 15px;
    height: 15px;
  }

  .lang-code {
    font-size: 13px;
    font-weight: bold;
    letter-spacing: 0.04em;
    line-height: 1;
  }

  .lang-select {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
    font-size: 16px;
  }

  .lang-select option {
    background: #111;
    color: #f3f5fe;
  }

  @media (max-width: 640px) {
    .lang-code {
      font-size: 12px;
    }
  }
</style>
