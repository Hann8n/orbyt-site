---
import { SUPPORTED_LOCALES, DEFAULT_LOCALE, LOCALE_LABELS, LOCALE_CODES, LOCALE_FLAG_COUNTRY, getFlagCountryCode } from '../i18n/utils'

interface Props {
  currentLocale: string
  currentPath?: string
  countryCode?: string
}

const { currentLocale, currentPath = '/', countryCode } = Astro.props
const allLocales = [DEFAULT_LOCALE, ...SUPPORTED_LOCALES]
const currentFlagCode = getFlagCountryCode(currentLocale, countryCode)
---

<div class="lang-switcher" role="group" aria-label="Language">
  <img
    src={`/flags/${currentFlagCode}.svg`}
    alt=""
    aria-hidden="true"
    class="lang-flag"
    width="20"
    height="15"
    loading="eager"
    decoding="sync"
    fetchpriority="high"
  />
  <span class="lang-code">{LOCALE_CODES[currentLocale]}</span>
  <select
    id="lang-select"
    class="lang-select"
    onchange="orbytSwitchLang(this.value)"
  >
    {allLocales.map((locale) => (
      <option value={locale} selected={locale === currentLocale}>
        {LOCALE_LABELS[locale]}
      </option>
    ))}
  </select>
</div>

<script is:inline define:vars={{ SUPPORTED_LOCALES, DEFAULT_LOCALE, currentPath }}>
  window.orbytSwitchLang = function (locale) {
    document.cookie = `orbyt-locale=${locale};max-age=31536000;path=/;samesite=lax`

    let path = currentPath
    for (const l of SUPPORTED_LOCALES) {
      if (path === `/${l}` || path.startsWith(`/${l}/`)) {
        path = path.slice(l.length + 1) || '/'
        break
      }
    }

    const dest = locale === DEFAULT_LOCALE
      ? (path || '/')
      : `/${locale}${path === '/' ? '/' : path}`

    window.location.href = dest
  }
</script>

<style>
  .lang-switcher {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    cursor: pointer;
    line-height: 1;
  }

  .lang-flag {
    display: block;
    width: 20px;
    height: 15px;
    object-fit: cover;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .lang-code {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--orbyt-neutral-500);
  }

  .lang-select {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
    font-size: 16px;
    appearance: none;
    -webkit-appearance: none;
    border: none;
    background: none;
    padding: 0;
    margin: 0;
  }

  .lang-select option {
    background: #111;
    color: #f3f5fe;
  }
</style>
