---
import { languages } from '../i18n/ui';

const currentLocale = Astro.props.currentLocale ?? 'en';
const currentUrl = Astro.url.pathname + Astro.url.search;
---

<ul class="profile-lang-picker" aria-label="Select language">
  {Object.entries(languages).map(([code, label]) => (
    <li>
      <a
        href={code === currentLocale ? '#' : `/api/set-locale?locale=${code}&redirect=${encodeURIComponent(currentUrl)}`}
        class:list={[code === currentLocale && 'current']}
        {...(code !== currentLocale && { 'data-no-prefetch': 'true' })}
      >
        {label}
      </a>
    </li>
  ))}
</ul>

<style>
  .profile-lang-picker {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
  }
  .profile-lang-picker a {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
  }
  .profile-lang-picker a:hover {
    color: rgba(255, 255, 255, 0.9);
  }
  .profile-lang-picker a.current {
    color: rgba(255, 255, 255, 0.95);
    font-weight: 600;
  }
</style>
