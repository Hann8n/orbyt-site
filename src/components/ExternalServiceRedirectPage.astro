---
import DocumentColorScheme from './DocumentColorScheme.astro';
import { SITE_DOCUMENT } from '../utils/site-document-theme';

interface Props {
  destinationUrl: string;
  title?: string;
  message?: string;
  emojis?: string;
}

const {
  destinationUrl,
  title = 'Redirecting - orbyt',
  message = 'routing you to your destination...',
  emojis = '🚙💨',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="orbyt-doc-dark">
<head>
  <meta charset="utf-8">
  <DocumentColorScheme
    colorScheme="dark"
    themeColor={SITE_DOCUMENT.orbytBlack}
    tileColor={SITE_DOCUMENT.orbytBlack}
  />
  <link rel="stylesheet" href="/css/tokens.css" />
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title}</title>
  <meta http-equiv="refresh" content={`0; url=${destinationUrl}`}>
  <link rel="canonical" href={destinationUrl}>
  <script is:inline define:vars={{ destinationUrl }}>
    window.location.href = destinationUrl;
  </script>
  <style>
    @font-face {
      font-family: 'Figtree';
      src: url('/fonts/Figtree/Figtree-VariableFont_wght.woff2') format('woff2');
      font-weight: 300 900;
      font-style: normal;
      font-display: fallback;
    }
    html, body {
      margin: 0;
      padding: 0;
      background: #000;
      color: #fff;
      height: 100vh;
    }
    body {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      position: relative;
    }
    .container {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 20px;
    }
    .emojis {
      font-size: 70px;
      line-height: 1;
    }
    .text {
      font-family: 'Figtree', sans-serif;
      font-weight: 300;
      font-size: 20px;
      color: #fff;
    }
    .logo-icon {
      width: 80px;
      height: auto;
      position: absolute;
      bottom: 40px;
    }
    .logo-icon .logo-fg {
      fill: #f3f5fe;
      stroke: #f3f5fe;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="emojis">{emojis}</div>
    <div class="text">{message}</div>
  </div>
  <svg class="logo-icon" xmlns="http://www.w3.org/2000/svg" viewBox="65 65 894 894">
