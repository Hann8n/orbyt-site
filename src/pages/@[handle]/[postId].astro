              </g>
            </svg>
            <span id="likes-count-mobile">0</span>
          </span>

        </div>

      </div>

      <div class="video-container">
        <video id="vinit" muted playsinline loop autoplay preload="auto" oncontextmenu="return false;">
        </video>
        <img id="video-thumbnail" class="video-thumbnail" src={thumbnail} alt="" style={`view-transition-name: video-${postId}`} />
      </div>

    </div>

    <div id="desktop">

      <div class="desktop-title">

        <div class="logo">
          <a href='/' class="logo-wordmark">
            <svg class="logo-wordmark-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 187 65">
