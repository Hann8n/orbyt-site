          </a>
        </div>

        <a class='install-button' href="/beta" style="view-transition-name: orbyt-beta;">
          Get the beta
          <svg class="svg-button" viewBox="0 0 21 22" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1.93892 19.9988L18.9736 2.96362" stroke-width="3.993"/>
          <path d="M19 16.7368L19 2.93875L5.20193 2.93875" stroke-width="3.993"/>
          </svg>
        </a>

      </div>

      <div id="post-overlay" class="post-overlay">

        <div class='mute-toggle-wrapper'>
          <button id="mute-toggle" aria-label="Toggle mute">
            <span id="mute-text">
              LOADING...
            </span>
          </button>
        </div>

        <div id="post-caption-mobile" class="post-content mobile-overlay" style={`view-transition-name: caption-${postId}`} set:html={parseRichText(caption)}></div>

        <div class="post-author mobile-overlay">

          <span class='avatar-wrapper'>
            <img id="author-avatar-mobile" class='avatar' src={authorAvatar} alt={`${authorDisplayName}'s avatar`}>
            <div class="username">
              <a id="author-link-mobile" href={`/@${authorHandle}`}>{authorDisplayName}</a>
            </div>
            <div id="post-time-mobile" style="display: none;"></div>
          </span>

          <span class='likes'>
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" style="display: block;">
              <g fill="none">
