---
export const prerender = true;

import Base from '../layouts/Base.astro';
import { useTranslations } from '../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
---

<Base lang={lang} title={t('beta.title')} noFooter={true}>
  <Fragment slot="head">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0" />
    <script is:inline async src="https://tally.so/widgets/embed.js"></script>
    <style is:inline>
      html { margin: 0; height: 100%; overflow: hidden; background: #000; }
      body { margin: 0; background: #000; }
      iframe { position: absolute; top: 0; right: 0; bottom: 0; left: 0; border: 0; }
    </style>
  </Fragment>
  <iframe data-tally-src="https://tally.so/r/nWx7zQ?transparentBackground=1&formEventsForwarding=1" width="100%" height="100%" style="border: 0; margin: 0;" title={t('beta.iframeTitle')}></iframe>
</Base>
