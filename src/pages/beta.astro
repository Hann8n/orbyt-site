---
export const prerender = true;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0"
    />
    <title>Android Beta sign up</title>
    <style>
      :root {
        color-scheme: dark;
      }

      html,
      body {
        margin: 0;
        width: 100%;
        height: 100%;
        min-height: 100dvh;
        overflow: hidden;
        background: #000;
      }

      body {
        position: relative;
      }

      iframe {
        position: absolute;
        inset: 0;
        display: block;
        width: 100%;
        height: 100%;
        min-height: 100dvh;
        border: 0;
        background: #000;
      }
    </style>
  </head>
  <body>
    <iframe
      src="https://tally.so/r/nWx7zQ?transparentBackground=1"
      title="Android Beta sign up"
      loading="eager"
      referrerpolicy="no-referrer-when-downgrade"
      allow="clipboard-write"
    ></iframe>
  </body>
</html>
