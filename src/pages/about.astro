---
export const prerender = true;

import Base from '../layouts/Base.astro';
import { useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<Base lang={lang} title={t('about.title')} description={t('about.metaDescription')} canonicalUrl="https://getorbyt.com/about/">
  <div class="container">
    <div class="header">
      <a href={translatePath('/')} class="logo">
        <img src="/images/orbyt-logo.svg" alt={t('common.orbytAlt')} />
      </a>
    </div>
    <div class="content">
      <h3>{t('about.questions')}</h3>
      <h2>{t('about.whatMakesDifferent')}</h2>
      <p>{t('about.whatMakesDifferentBody')}</p>
      <h2>{t('about.howBuilt')}</h2>
      <p>{t('about.howBuiltBody')}</p>
      <h2>{t('about.whereIdea')}</h2>
      <p>{t('about.whereIdeaBody')}</p>
      <h2>{t('about.whatsNext')}</h2>
      <p set:html={t('about.whatsNextBody')
        .replace('{bluesky}', '<a href="https://bsky.app/profile/getorbyt.com">Bluesky</a>')
        .replace('{community}', '<a href="https://community.getorbyt.com">community forum</a>')
        .replace('{sayHello}', `<a href="${translatePath('/contact')}">${t('about.sayHello')}</a>`)} />
    </div>
  </div>
</Base>

<style define:vars={{ avatarBorderColor: '#ccd7e9' }}>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'Figtree', sans-serif; background: #000; min-height: 100vh; color: #f3f5fe; }
  .container { max-width: 800px; margin: 0 auto; padding: 2rem; min-height: 100vh; display: flex; flex-direction: column; }
  .header { text-align: left; margin-bottom: 1.5rem; padding-bottom: 2rem; }
  .logo { display: block; margin-bottom: 2rem; }
  .logo img { width: 80px; height: 80px; }
  .content h2 { font-size: 1.8rem; color: #f3f5fe; margin: 2rem 0 1rem 0; font-weight: 900; }
  .content h3 { font-size: 1.2rem; color: #cfd6e8; margin: 2rem 0 0.5rem 0; font-weight: 500; text-transform: uppercase; letter-spacing: 0.1em; }
  .content p { font-size: 1rem; color: #cfd6e8; margin-bottom: 1rem; line-height: 1.7; }
  .content a { color: #01f5b3; text-decoration: none; }
  @media (max-width: 768px) {
    .container { padding: 1rem; }
    .content h2 { font-size: 1.5rem; }
    .content h3 { font-size: 1rem; }
  }
</style>
