---
export const prerender = true;
import SiteClientRouterHeadStyles from '../components/SiteClientRouterHeadStyles.astro';
import { ClientRouter } from 'astro:transitions';
---

<!doctype html>
<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0">
    <title>Android Beta sign up</title>
    <SiteClientRouterHeadStyles />
    <ClientRouter />
    <script is:inline async src="https://tally.so/widgets/embed.js"></script>
    <style is:global>
      html, body { margin: 0; height: 100%; overflow: hidden; background: #000; }
      iframe { position: absolute; top: 0; right: 0; bottom: 0; left: 0; border: 0; background: #000; }
    </style>
  </head>
  <body>
    <iframe
      data-tally-src="https://tally.so/r/nWx7zQ"
      data-tally-theme="dark"
      width="100%"
      height="100%"
      frameborder="0"
      marginheight="0"
      marginwidth="0"
      title="Android Beta sign up"
    ></iframe>
  </body>
</html>
