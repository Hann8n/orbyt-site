---
export const prerender = true;

import Base from '../layouts/Base.astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<Base lang={lang} title={t('404.title')} noFooter={false}>
  <div class="container">
    <div class="main-content">
      <div class="tv-static" aria-hidden="true"></div>
      <h1 class="error-title">{t('404.errorTitle')}</h1>
      <p class="error-message">{t('404.errorMessage')}</p>
      <a href="#" onclick="window.history.back(); return false;" class="nav-button">{t('404.goBack')}</a>
    </div>
  </div>
</Base>

<style>
  .container { width: min(100% - clamp(2rem, 5vw, 4rem), 800px); margin-inline: auto; min-height: 100vh; display: flex; flex-direction: column; }
  .main-content { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; gap: clamp(0.75rem, 2vw, 1rem); padding-block: clamp(2rem, 8vh, 6rem); }
  .tv-static { width: clamp(120px, 20vw, 160px); aspect-ratio: 1; background-image: url('/images/tv-static-sprite-sheet.webp'); background-size: 500% 500%; animation: tv-static-animation 0.8s steps(1) infinite; }
  @keyframes tv-static-animation { 0% { background-position: 0% 0%; } 4% { background-position: 25% 0%; } 8% { background-position: 50% 0%; } 12% { background-position: 75% 0%; } 16% { background-position: 100% 0%; } 20% { background-position: 0% 25%; } 24% { background-position: 25% 25%; } 28% { background-position: 50% 25%; } 32% { background-position: 75% 25%; } 36% { background-position: 100% 25%; } 40% { background-position: 0% 50%; } 44% { background-position: 25% 50%; } 48% { background-position: 50% 50%; } 52% { background-position: 75% 50%; } 56% { background-position: 100% 50%; } 60% { background-position: 0% 75%; } 64% { background-position: 25% 75%; } 68% { background-position: 50% 75%; } 72% { background-position: 75% 75%; } 76% { background-position: 100% 75%; } 80% { background-position: 0% 100%; } 84% { background-position: 25% 100%; } 88% { background-position: 50% 100%; } 92% { background-position: 75% 100%; } 96% { background-position: 100% 100%; } }
  .error-title { font-size: clamp(2rem, 5vw, 2.5rem); font-weight: 900; line-height: 1; letter-spacing: -0.02em; }
  .error-message { font-size: clamp(1rem, 2vw, 1.125rem); color: #9ca3af; max-width: 32ch; line-height: 1.5; }
  .nav-button { display: inline-flex; background: #f3f5fe; color: #000; text-decoration: none; padding: 0.625rem 1.25rem; border-radius: 999px; font-size: 0.875rem; font-weight: 700; margin-top: 0.5rem; }
  .nav-button:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(255, 255, 255, 0.1); }
</style>
