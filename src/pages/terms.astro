---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Terms of Use - Orbyt</title>
    
    <!-- Favicon setup -->
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon_io/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon_io/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon_io/favicon-16x16.png">
    <link rel="icon" href="/favicon_io/favicon.ico">
    <link rel="manifest" href="/favicon_io/site.webmanifest">
    
    <!-- Theme colors for mobile browsers -->
    <meta name="theme-color" content="#ffffff">
    <meta name="msapplication-TileColor" content="#ffffff">
    <style>
      @font-face {
        font-family: 'Figtree';
        src: url('/fonts/Figtree/Figtree-VariableFont_wght.ttf') format('truetype');
        font-weight: 300 900;
        font-style: normal;
        font-display: swap;
      }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Figtree', -apple-system, BlinkMacSystemFont, sans-serif;
            background: #000000;
            min-height: 100vh;
            color: white;
            position: relative;
            overflow-x: hidden;
            overflow-y: auto;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
            padding: 2rem;
            min-height: 100vh;
        }

        .header {
            text-align: left;
            margin-bottom: 1.5rem;
            padding-bottom: 2rem;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            color: #cfd6e8;
            text-decoration: none;
            font-size: 1rem;
            font-family: 'Figtree', -apple-system, BlinkMacSystemFont, sans-serif;
            font-weight: 700;
            margin-bottom: 2rem;
            transition: color 0.3s ease;
        }

        .back-link:hover {
            color: #ffffff;
        }

        .back-link svg {
            width: 20px;
            height: 20px;
            margin-right: 0.5rem;
            fill: currentColor;
            transition: color 0.3s ease;
        }

        h1 {
            font-family: 'Figtree', -apple-system, BlinkMacSystemFont, sans-serif;
            font-size: 3rem;
            font-weight: 900;
            color: white;
            margin-bottom: 1rem;
        }

        .subtitle {
            font-family: 'Figtree', -apple-system, BlinkMacSystemFont, sans-serif;
            font-size: 0.9rem;
            color: #cfd6e8;
            opacity: 0.8;
        }

        .content {
            line-height: 1.6;
        }

        .content h2 {
            font-family: 'Figtree', -apple-system, BlinkMacSystemFont, sans-serif;
            font-size: 1.8rem;
            color: white;
            margin: 2rem 0 1rem 0;
            font-weight: 900;
        }

        .content h3 {
            font-family: 'Figtree', -apple-system, BlinkMacSystemFont, sans-serif;
            font-size: 1.4rem;
            color: white;
            margin: 1.5rem 0 0.5rem 0;
            font-weight: 900;
        }

        .content p {
            font-family: 'Figtree', -apple-system, BlinkMacSystemFont, sans-serif;
            font-size: 1rem;
            color: #cfd6e8;
            margin-bottom: 1rem;
        }

        .content ul {
            margin: 1rem 0;
            padding-left: 2rem;
        }

        .content li {
            font-family: 'Figtree', -apple-system, BlinkMacSystemFont, sans-serif;
            font-size: 1rem;
            color: #cfd6e8;
            margin-bottom: 0.5rem;
        }

        .content strong {
            color: white;
            font-weight: 600;
        }

        .content a {
            color: #3797F0;
            text-decoration: none;
            transition: color 0.3s ease;
        }

        .content a:hover {
            color: #2A7CD6;
        }

        .separator {
            height: 20px;
            margin-top: 80px;
            margin-bottom: 40px;
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .separator svg {
            width: 100%;
            min-width: 200px;
            height: 20px;
            overflow: visible;
        }

        .footer {
            text-align: left;
            white-space: nowrap;
            display: block;
            margin-bottom: 40px;
        }

        .footer a {
            margin: 0 20px 0 0;
            display: inline-block;
            font-style: normal;
            font-weight: bold;
            font-size: 13px;
            text-align: left;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            text-decoration: none;
            color: #ccc;
        }

        .footer a:hover {
            color: #fff;
        }

        @media (max-width: 768px) {
            .container {
                padding: 1rem;
            }

            h1 {
                font-size: 2.5rem;
            }

            .content h2 {
                font-size: 1.5rem;
            }

            .content h3 {
                font-size: 1.2rem;
            }

            .separator {
                margin-top: 80px;
                margin-bottom: 40px;
            }

            .footer {
                white-space: normal;
                margin-bottom: 40px;
                text-align: center;
            }

            .footer a {
                display: block;
                margin: 8px 0 8px 0;
                text-align: center;
            }
        }
    </style>
</head>
<body>


