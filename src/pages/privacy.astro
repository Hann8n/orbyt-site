---
export const prerender = false;

import DocumentColorScheme from '../components/DocumentColorScheme.astro';
import SiteClientRouterHeadStyles from '../components/SiteClientRouterHeadStyles.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SkipToContent from '../components/SkipToContent.astro';
import { SITE_DOCUMENT } from '../utils/site-document-theme';
import { ClientRouter } from 'astro:transitions';
import { useTranslations, localeToHtmlLang } from '../i18n/utils';
import { getPrivacyContent } from '../i18n/legal/privacy-content';

const locale = Astro.locals.locale ?? 'en';
const countryCode = Astro.locals.countryCode;
const t = useTranslations(locale);
const privacyBody = getPrivacyContent(locale);
---
<!DOCTYPE html>
<html lang={localeToHtmlLang(locale)} class="orbyt-doc-dark">
<head>
    <meta charset="UTF-8">
    <DocumentColorScheme
      colorScheme="dark"
      themeColor={SITE_DOCUMENT.orbytBlack}
      tileColor={SITE_DOCUMENT.orbytBlack}
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{t('privacy.title')}</title>
    <ClientRouter />

    <link rel="preload" href="/fonts/Figtree/Figtree-VariableFont_wght.woff2" as="font" type="font/woff2" crossorigin>

    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png">
    <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png">
    <link rel="manifest" href="/favicon/site.webmanifest">
    <SiteClientRouterHeadStyles documentShell />
</head>
<body>
    <SkipToContent />

    <div class="site-doc">
        <div class="site-doc__content">
            <a href="/" class="site-doc__logo">
                <img src="/images/orbyt-logo.svg" alt={t('privacy.logo.alt')}>
            </a>
            <div class="site-doc__content-main">
                <header class="site-doc__masthead">
                <h1>{t('privacy.heading')}</h1>
                <p class="site-doc__subtitle">{t('privacy.last_updated')}</p>
                </header>

                <main id="main-content" class="site-doc__prose" set:html={privacyBody} />
            </div>
        </div>

        <SiteFooter locale={locale} currentPath="/privacy" countryCode={countryCode} />
    </div>

</body>
</html>
