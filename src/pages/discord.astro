---
export const prerender = true;
---
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Discord - orbyt</title>
    <meta http-equiv="refresh" content="0; url=https://discord.gg/8gNQPFygnF">
    <link rel="canonical" href="https://discord.gg/8gNQPFygnF">
    <script>
        window.location.href = "https://discord.gg/8gNQPFygnF";
    </script>
    <style>
        @font-face {
            font-family: 'Figtree';
            src: url('/fonts/Figtree/Figtree-VariableFont_wght.woff2') format('woff2');
            font-weight: 300 900;
            font-style: normal;
            font-display: fallback;
        }
        html, body {
            margin: 0;
            padding: 0;
            background: #000;
            color: #fff;
            height: 100vh;
        }
        body {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            position: relative;
        }
        .container {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 20px;
        }
        .emojis {
            font-size: 70px;
            line-height: 1;
        }
        .text {
            font-family: 'Figtree', sans-serif;
            font-weight: 300;
            font-size: 20px;
            color: #fff;
        }
        .logo-text {
            font-family: 'Figtree', sans-serif;
            font-weight: 900;
            font-size: 48px;
            color: #f3f5fe;
            position: absolute;
            bottom: 40px;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="emojis">🚙💨</div>
        <div class="text">routing you to discord...</div>
    </div>
    <div class="logo-text">orbyt</div>
</body>
</html>
