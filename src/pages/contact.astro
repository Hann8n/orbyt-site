---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us - Orbyt</title>
    
    <!-- Critical: Inline font-face for immediate availability (no network delay) -->
    <style>
      @font-face {
        font-family: 'Figtree';
        src: url('/fonts/Figtree/Figtree-VariableFont_wght.woff2') format('woff2');
        font-weight: 300 900;
        font-style: normal;
        font-display: fallback; /* Short block window, then swap - prevents FOUT */
      }
    </style>
    <!-- Preload Figtree font to start download early -->
    <link rel="preload" href="/fonts/Figtree/Figtree-VariableFont_wght.woff2" as="font" type="font/woff2" crossorigin>
    
    <!-- Favicon setup -->
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png">
    <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png">
    <link rel="manifest" href="/favicon/site.webmanifest">
    
    <!-- Theme colors for mobile browsers -->
    <meta name="theme-color" content="#f3f5fe">
    <meta name="msapplication-TileColor" content="#f3f5fe">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Figtree', -apple-system, BlinkMacSystemFont, sans-serif;
            background: #000000;
            min-height: 100vh;
            color: #f3f5fe;
            position: relative;
            overflow-x: hidden;
            overflow-y: auto;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
            padding: 2rem;
            min-height: 100vh;
        }

        .header {
            text-align: left;
            margin-bottom: 1.5rem;
            padding-bottom: 2rem;
        }

        .logo {
            display: block;
            margin-bottom: 2rem;
        }

        .logo img {
            width: 80px;
            height: 80px;
        }

        h1 {
            font-family: 'Figtree', -apple-system, BlinkMacSystemFont, sans-serif;
            font-size: 3rem;
            font-weight: 900;
            color: #f3f5fe;
            margin-bottom: 1rem;
        }

        .content {
            line-height: 1.6;
        }

        .content h2 {
            font-family: 'Figtree', -apple-system, BlinkMacSystemFont, sans-serif;
            font-size: 1.8rem;
            color: #f3f5fe;
            margin: 2rem 0 1rem 0;
            font-weight: 900;
        }

        .content p {
            font-family: 'Figtree', -apple-system, BlinkMacSystemFont, sans-serif;
            font-size: 1rem;
            color: #cfd6e8;
            margin-bottom: 1rem;
        }

        .content a {
            color: #01f5b3;
            text-decoration: none;
            transition: color 0.3s ease;
        }

        .content a:hover {
            color: #01f5b3;
        }

        .separator {
            height: 7px;
            margin-bottom: 40px;
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: flex-start;
            width: 100%;
        }

        .separator svg {
            width: 100%;
            height: 7px;
        }

        .footer {
            text-align: left;
            white-space: nowrap;
            display: block;
            margin-top: 80px;
            margin-bottom: 40px;
        }

        .footer a {
            margin: 0 20px 0 0;
            display: inline-block;
            font-style: normal;
            font-weight: bold;
            font-size: 13px;
            text-align: left;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            text-decoration: none;
            color: #ccc;
        }

        .footer a:hover {
            color: #f3f5fe;
        }

        @media (max-width: 768px) {
            .container {
                padding: 1rem;
            }

            h1 {
                font-size: 2.5rem;
            }

            .content h2 {
                font-size: 1.5rem;
            }

            .separator {
                margin-bottom: 40px;
            }

            .footer {
                white-space: normal;
                margin-bottom: 40px;
                text-align: center;
            }

            .footer a {
                display: block;
                margin: 8px 0 8px 0;
                text-align: center;
            }
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="header">
            <a href="/" class="logo">
                <img src="/images/orbyt-logo.svg" alt="Orbyt">
            </a>
            <h1>Contact Us</h1>
        </div>

        <div class="content">
            
            <h2>For general inquiries</h2>
            <p><a href="mailto:hello@getorbyt.com">hello@getorbyt.com</a></p>
            
            <h2>Press &amp; media requests</h2>
            <p><a href="mailto:hello@getorbyt.com">hello@getorbyt.com</a></p>
            
            <h2>Bug reports</h2>
            <p><a href="mailto:support@getorbyt.com">support@getorbyt.com</a></p>
            
            <h2>Copyright, trademark, and IP-related issues</h2>
            <p><a href="/terms">Terms of Use</a></p>
            <p><a href="mailto:legal@getorbyt.com">legal@getorbyt.com</a></p>
        </div>

        <div class="footer">
            <div class="separator">
                <svg height="7" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <defs>
                        <pattern id="squigglePattern" width="374" height="7" patternUnits="userSpaceOnUse">
                            <path d="M0 1C5.50021 1 5.50021 5.84456 11.0004 5.84456C16.5006 5.84456 16.5006 1 22.0008 1C27.501 1 27.501 5.84456 33.0013 5.84456C38.5015 5.84456 38.5015 1 44.0017 1C49.5019 1 49.5019 5.84456 55.0021 5.84456C60.5023 5.84456 60.5023 1 66.0025 1C71.5027 1 71.5027 5.84456 77.0029 5.84456C82.5031 5.84456 82.5031 1 87.9998 1C93.5 1 93.5 5.84456 98.9967 5.84456C104.497 5.84456 104.497 1 109.994 1C115.494 1 115.494 5.84456 120.99 5.84456C126.491 5.84456 126.491 1 131.991 1C137.491 1 137.491 5.84456 142.991 5.84456C148.491 5.84456 148.491 1 153.992 1C159.492 1 159.492 5.84456 164.988 5.84456C170.489 5.84456 170.489 1 175.985 1C181.486 1 181.486 5.84456 186.986 5.84456C192.486 5.84456 192.486 1 197.986 1C203.486 1 203.486 5.84456 208.987 5.84456C214.487 5.84456 214.487 1 219.987 1C225.487 1 225.487 5.84456 230.987 5.84456C236.488 5.84456 236.488 1 241.988 1C247.488 1 247.488 5.84456 252.988 5.84456C258.488 5.84456 258.488 1 263.989 1C269.489 1 269.489 5.84456 274.989 5.84456C280.489 5.84456 280.489 1 285.99 1C291.49 1 291.49 5.84456 296.99 5.84456C302.49 5.84456 302.49 1 307.99 1C313.491 1 313.491 5.84456 318.991 5.84456C324.491 5.84456 324.491 1 329.991 1C335.491 1 335.491 5.84456 340.992 5.84456C346.492 5.84456 346.492 1 351.992 1C357.492 1 357.492 5.84456 362.996 5.84456C368.5 5.84456 368.496 1 374 1" stroke="#551DEF" stroke-width="2" stroke-miterlimit="10"/>
                        </pattern>
                    </defs>
                    <rect fill="url(#squigglePattern)" width="100%" height="100%"/>
                </svg>
            </div>
            <a href="https://bsky.app/profile/getorbyt.com">bluesky</a>
            <a href="https://discord.gg/8gNQPFygnF">discord</a>
            <a href="/terms">terms</a>
            <a href="/privacy">privacy</a>
            <a href="/contact">contact</a>
        </div>
    </div>

</body>
</html>
