                    <rect class="logo-bg" x="372" y="482" width="82" height="136" rx="41" ry="41"/>
                    <rect class="logo-bg" x="570" y="482" width="82" height="136" rx="41" ry="41"/>
                </svg>
            </a>
        </div>

        <div class="content">
            <h1>Contact Us</h1>
            
            <h2>For general inquiries</h2>
            <p><a href="mailto:hello@getorbyt.com">hello@getorbyt.com</a></p>
            
