---
export const prerender = true;

import Base from '../layouts/Base.astro';
import { useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<Base lang={lang} title={t('contact.title')} canonicalUrl="https://getorbyt.com/contact/">
  <div class="container">
    <div class="header">
      <a href={translatePath('/')} class="logo">
        <img src="/images/orbyt-logo.svg" alt={t('common.orbytAlt')} />
      </a>
      <h1>{t('contact.title').replace(' - Orbyt', '')}</h1>
    </div>
    <div class="content">
      <h2>{t('contact.generalInquiries')}</h2>
      <p><a href="mailto:hello@getorbyt.com">hello@getorbyt.com</a></p>
      <h2>{t('contact.pressMedia')}</h2>
      <p><a href="mailto:press@getorbyt.com">press@getorbyt.com</a></p>
      <h2>{t('contact.bugReports')}</h2>
      <p><a href="mailto:support@getorbyt.com">support@getorbyt.com</a></p>
      <h2>{t('contact.copyrightIssues')}</h2>
      <p>{t('contact.copyrightBody')}</p>
    </div>
  </div>
</Base>

<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'Figtree', sans-serif; background: #000; min-height: 100vh; color: #f3f5fe; }
  .container { max-width: 800px; margin: 0 auto; padding: 2rem; min-height: 100vh; display: flex; flex-direction: column; }
  .header { text-align: left; margin-bottom: 1.5rem; padding-bottom: 2rem; }
  .logo { display: block; margin-bottom: 2rem; }
  .logo img { width: 80px; height: 80px; }
  h1 { font-size: 3rem; font-weight: 900; color: #f3f5fe; margin-bottom: 1rem; }
  .content h2 { font-size: 1.8rem; color: #f3f5fe; margin: 2rem 0 1rem 0; font-weight: 900; }
  .content p { font-size: 1rem; color: #cfd6e8; margin-bottom: 1rem; }
  .content a { color: #01f5b3; text-decoration: none; }
</style>
