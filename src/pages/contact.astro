---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us - Orbyt</title>
    
    <!-- Critical: Inline font-face for immediate availability (no network delay) -->
    <style>
      @font-face {
        font-family: 'Figtree';
        src: url('/fonts/Figtree/Figtree-VariableFont_wght.woff2') format('woff2');
        font-weight: 300 900;
        font-style: normal;
        font-display: fallback; /* Short block window, then swap - prevents FOUT */
      }
    </style>
    <!-- Preload Figtree font to start download early -->
    <link rel="preload" href="/fonts/Figtree/Figtree-VariableFont_wght.woff2" as="font" type="font/woff2" crossorigin>
    
    <!-- Favicon setup -->
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png">
    <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png">
    <link rel="manifest" href="/favicon/site.webmanifest">
    
    <!-- Theme colors for mobile browsers -->
    <meta name="theme-color" content="#f3f5fe">
    <meta name="msapplication-TileColor" content="#f3f5fe">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Figtree', -apple-system, BlinkMacSystemFont, sans-serif;
            background: #000000;
            min-height: 100vh;
            color: #f3f5fe;
            position: relative;
            overflow-x: hidden;
            overflow-y: auto;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
            padding: 2rem;
            min-height: 100vh;
        }

        .header {
            text-align: left;
            margin-bottom: 0.5rem;
            padding-bottom: 0.5rem;
        }

        .header a {
            display: inline-block;
            text-decoration: none;
        }

        .logo-icon {
            width: 100px;
            height: auto;
            display: block;
            margin: 0;
            color: #f3f5fe;
        }

        .logo-icon .logo-bg {
            fill: #000000;
        }

        .logo-icon .logo-fg {
            fill: #f3f5fe;
            stroke: #f3f5fe;
        }

        .logo-icon .logo-outline {
            fill: none;
        }

        .logo-text {
            font-family: 'Figtree', -apple-system, BlinkMacSystemFont, sans-serif;
            font-weight: 900;
            font-size: 32px;
            color: #f3f5fe;
            text-align: center;
            text-box-trim: trim-start;
            text-box-edge: cap alphabetic;
            display: block;
        }

        h1 {
            font-family: 'Figtree', -apple-system, BlinkMacSystemFont, sans-serif;
            font-size: 3rem;
            font-weight: 900;
            color: #f3f5fe;
            margin-bottom: 1rem;
        }

        .content {
            line-height: 1.6;
        }

        .content h2 {
            font-family: 'Figtree', -apple-system, BlinkMacSystemFont, sans-serif;
            font-size: 1.8rem;
            color: #f3f5fe;
            margin: 2rem 0 1rem 0;
            font-weight: 900;
        }

        .content p {
            font-family: 'Figtree', -apple-system, BlinkMacSystemFont, sans-serif;
            font-size: 1rem;
            color: #cfd6e8;
            margin-bottom: 1rem;
        }

        .content a {
            color: #01f5b3;
            text-decoration: none;
            transition: color 0.3s ease;
        }

        .content a:hover {
            color: #01f5b3;
        }

        .separator {
            height: 7px;
            margin-top: 80px;
            margin-bottom: 40px;
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: flex-start;
            width: 100%;
        }

        .separator svg {
            width: 100%;
            height: 7px;
        }

        .footer {
            text-align: left;
            white-space: nowrap;
            display: block;
            margin-bottom: 40px;
        }

        .footer a {
            margin: 0 20px 0 0;
            display: inline-block;
            font-style: normal;
            font-weight: bold;
            font-size: 13px;
            text-align: left;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            text-decoration: none;
            color: #ccc;
        }

        .footer a:hover {
            color: #f3f5fe;
        }

        @media (max-width: 768px) {
            .container {
                padding: 1rem;
            }

            h1 {
                font-size: 2.5rem;
            }

            .content h2 {
                font-size: 1.5rem;
            }

            .separator {
                margin-top: 80px;
                margin-bottom: 40px;
            }

            .footer {
                white-space: normal;
                margin-bottom: 40px;
                text-align: center;
            }

            .footer a {
                display: block;
                margin: 8px 0 8px 0;
                text-align: center;
            }
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="header">
            <a href="/">
