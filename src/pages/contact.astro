---
export const prerender = true;

import DocumentColorScheme from '../components/DocumentColorScheme.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { SITE_DOCUMENT } from '../utils/site-document-theme';
---
<!DOCTYPE html>
<html lang="en" class="orbyt-doc-dark">
<head>
    <meta charset="UTF-8">
    <DocumentColorScheme
      colorScheme="dark"
      themeColor={SITE_DOCUMENT.orbytBlack}
      tileColor={SITE_DOCUMENT.orbytBlack}
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us - Orbyt</title>

    <link rel="preload" href="/fonts/Figtree/Figtree-VariableFont_wght.woff2" as="font" type="font/woff2" crossorigin>

    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png">
    <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png">
    <link rel="manifest" href="/favicon/site.webmanifest">
    <link rel="stylesheet" href="/css/tokens.css" />
    <link rel="stylesheet" href="/css/site-document.css" />
</head>
<body>

    <div class="site-doc">
        <header class="site-doc__masthead">
            <a href="/" class="site-doc__logo">
                <img src="/images/orbyt-logo.svg" alt="Orbyt">
            </a>
            <h1>Contact Us</h1>
        </header>

        <main class="site-doc__prose">

            <h2>For general inquiries</h2>
            <p><a href="mailto:hello@getorbyt.com">hello@getorbyt.com</a></p>

            <h2>Press &amp; media requests</h2>
            <p><a href="mailto:press@getorbyt.com">press@getorbyt.com</a></p>

            <h2>Bug reports</h2>
            <p><a href="mailto:support@getorbyt.com">support@getorbyt.com</a></p>

            <h2>Copyright and content issues</h2>
            <p>Orbyt is a third-party client for Bluesky. Content is hosted on the AT Protocol network, not by Orbyt. For copyright takedowns or content-related legal issues, please contact <a href="https://bsky.social/about/support" target="_blank" rel="noopener">Bluesky Support</a> directly.</p>
        </main>

        <SiteFooter />
    </div>

</body>
</html>
