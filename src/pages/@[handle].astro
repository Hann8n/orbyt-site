      </div>
    </header>

    <div class="posts">
      {videoPosts.map((post) => (
        <div class="post">
          <div class="post-image-container">
            <img class="post-placeholder" src="/images/post/placeholder.png" alt="" />
            <img class="post-thumb" src={post.thumbnail} alt="" style={`view-transition-name: video-${post.postId}`} />
            <div class="post-overlay">
              <div class="caption" style={`view-transition-name: caption-${post.postId}`} set:html={parseRichText(post.caption)}></div>
            </div>
          </div>
          <a href={`/@${handle}/${post.postId}`}>
            <img class="play-button" src="/images/post/play.svg" alt="" />
          </a>
        </div>
      ))}
      {nextCursor && (
        <footer>
          <a id="load-more" style={`background-color: ${textColor}; color: ${backgroundColor};`}>Load more</a>
        </footer>
      )}
    </div>
  </div>

<script>
  // Load more pagination using Astro server actions
  // Captions are pre-rendered server-side, no client-side parsing needed
  import { actions } from "astro:actions";

  function setupLoadMore() {
    const profileEl = document.getElementById('profile');
    const loadMoreBtn = document.getElementById('load-more');
    if (!profileEl || !loadMoreBtn) return;
    
    const handle = profileEl.dataset.handle;
    let cursor = profileEl.dataset.cursor;
    
    loadMoreBtn.addEventListener('click', async (e) => {
      e.preventDefault();
      if (!cursor) return;
      
      loadMoreBtn.textContent = 'Loading...';
      
      try {
        const { data, error } = await actions.loadMorePosts({ handle: handle || '', cursor });
        
        if (error || !data?.posts?.length) {
          loadMoreBtn.parentElement?.remove();
          return;
        }
        
        const postsContainer = document.querySelector('.posts');
        const footer = document.querySelector('footer');
        
        for (const post of data.posts) {
          const postDiv = document.createElement('div');
          postDiv.className = 'post';
          postDiv.innerHTML = `
            <div class="post-image-container">
              <img class="post-placeholder" src="/images/post/placeholder.png" alt="" />
              <img class="post-thumb" src="${post.thumbnail}" alt="" style="view-transition-name: video-${post.postId}" />
              <div class="post-overlay">
                <div class="caption" style="view-transition-name: caption-${post.postId}">${post.captionHtml}</div>
              </div>
            </div>
            <a href="/@${handle}/${post.postId}">
              <img class="play-button" src="/images/post/play.svg" alt="" />
            </a>
          `;
          
          if (footer) {
            postsContainer?.insertBefore(postDiv, footer);
          } else {
            postsContainer?.appendChild(postDiv);
          }
        }
        
        cursor = data.nextCursor || null;
        profileEl.dataset.cursor = cursor || '';
        
        if (cursor) {
          loadMoreBtn.textContent = 'Load more';
        } else {
          loadMoreBtn.parentElement?.remove();
        }
      } catch (error) {
        console.error('Error loading more:', error);
        loadMoreBtn.textContent = 'Load more';
      }
    });
  }
  
  // Run on page load and view transitions
  document.addEventListener('astro:page-load', setupLoadMore);
</script>

</body>
</html>
