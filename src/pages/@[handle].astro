---
export const prerender = false; // SSR route (shell-only, lightweight)

import { fetchProfile, toAbsoluteUrl, getImageMimeType } from '../utils/bluesky-api';

const { handle } = Astro.params;
// handle is "wsj.com" (no @ prefix)

// Fetch profile data for Open Graph metadata
let profileData = null;
if (handle) {
  profileData = await fetchProfile(handle);
}

// Return 404 if profile not found
if (!profileData) {
  return new Response(null, { status: 404 });
}

// Extract metadata with fallbacks
const displayName = profileData?.displayName || handle || 'Profile';
const description = profileData?.description || `Profile page for @${handle}`;
const avatar = profileData?.avatar || '/images/Default-avatar.png';
const ogImage = toAbsoluteUrl(avatar);
const ogUrl = `https://getorbyt.com/@${handle}`;
const ogTitle = `@${handle} on orbyt`;
const ogDescription = description.length > 200 ? description.substring(0, 200) + '...' : description;

// OG image properties - avatars are typically square, default to 1200x1200
const ogImageWidth = 1200;
const ogImageHeight = 1200;
const ogImageType = getImageMimeType(avatar);
const ogImageAlt = description.length > 200 ? description.substring(0, 200) : description;
---

<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">

    <link rel="stylesheet" href="/css/normalize.css">
    <link rel="stylesheet" href="/css/skeleton.css">
    <link rel="stylesheet" href="/css/shared.css">
    <link rel="stylesheet" href="/css/profile.css">

    <title>{ogTitle}</title>
    <meta name="description" content={ogDescription} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content={ogImageType} />
    <meta property="og:image:width" content={ogImageWidth.toString()} />
    <meta property="og:image:height" content={ogImageHeight.toString()} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:type" content="profile" />
    <meta property="profile:username" content={handle} />
    <meta property="og:site_name" content="orbyt" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Favicon setup -->
    <!-- iOS apple-touch-icon (iOS doesn't support media queries, use dark icon) -->
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon_dark/apple-touch-icon.png">

    <!-- Default/fallback favicons (for unsupported browsers - use favicon_io) -->
    <link rel="icon" type="image/x-icon" href="/favicon_io/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon_io/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon_io/favicon-16x16.png">

    <!-- Light mode favicons (desktop only - mobile/iOS will use fallback) -->
    <link rel="icon" type="image/x-icon" href="/favicon_light/favicon.ico" media="(prefers-color-scheme: light) and (min-width: 768px)">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon_light/favicon-16x16.png" media="(prefers-color-scheme: light) and (min-width: 768px)">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon_light/favicon-32x32.png" media="(prefers-color-scheme: light) and (min-width: 768px)">

    <!-- Dark mode favicons (desktop only - mobile/iOS will use fallback) -->
    <link rel="icon" type="image/x-icon" href="/favicon_dark/favicon.ico" media="(prefers-color-scheme: dark) and (min-width: 768px)">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon_dark/favicon-16x16.png" media="(prefers-color-scheme: dark) and (min-width: 768px)">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon_dark/favicon-32x32.png" media="(prefers-color-scheme: dark) and (min-width: 768px)">
    
    <link rel="manifest" href="/favicon_io/site.webmanifest">

    <style>
      @font-face {
        font-family: 'Figtree';
        src: url('/fonts/Figtree/Figtree-VariableFont_wght.ttf') format('truetype');
        font-weight: 300 900;
        font-style: normal;
        font-display: swap;
      }
      header .logo-wordmark {
        display: flex;
        align-items: center;
        text-decoration: none;
        transition: opacity 0.2s ease;
      }
      header .logo-wordmark:hover {
        opacity: 0.8;
      }
      header .logo-text {
        font-family: 'Figtree', sans-serif;
        font-weight: 900;
        font-size: 42px;
        letter-spacing: -0.02em;
        line-height: 1;
        color: #ccd7e9;
      }
      .install-button {
        background-color: #ccd7e9 !important;
        color: black !important;
      }
      .install-button .svg-button {
        display: inline-block;
        width: 16px;
        height: 16px;
        flex-shrink: 0;
        margin-left: 8px;
        transition: transform 0.2s ease;
      }
      .install-button:hover .svg-button {
        transform: translateX(2px);
      }
      .install-button .svg-button path {
        stroke: black !important;
        fill: none;
        stroke-linecap: round;
        stroke-linejoin: round;
      }
      @media screen and (max-width: 540px) {
        header .logo-text {
          font-size: 32px;
        }
      }
    </style>
</head>

<body>
  <div id="profile" data-handle={handle}>
    <header class="hidden">
      <div class="links">
        <a href='/' class="logo-wordmark">
          <span class="logo-text">orbyt</span>
        </a>
        <a class='install-button mobile' href="/beta">
          Waitlist
          <svg class="svg-button" viewBox="0 0 21 22" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1.93892 19.9988L18.9736 2.96362" stroke="black" stroke-width="3.993"/>
          <path d="M19 16.7368L19 2.93875L5.20193 2.93875" stroke="black" stroke-width="3.993"/>
          </svg>
        </a>
      </div>

      <svg class="hr-inline mobile" height="7" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="squigglePattern" width="374" height="7" patternUnits="userSpaceOnUse">
            <path d="M0 1C5.50021 1 5.50021 5.84456 11.0004 5.84456C16.5006 5.84456 16.5006 1 22.0008 1C27.501 1 27.501 5.84456 33.0013 5.84456C38.5015 5.84456 38.5015 1 44.0017 1C49.5019 1 49.5019 5.84456 55.0021 5.84456C60.5023 5.84456 60.5023 1 66.0025 1C71.5027 1 71.5027 5.84456 77.0029 5.84456C82.5031 5.84456 82.5031 1 87.9998 1C93.5 1 93.5 5.84456 98.9967 5.84456C104.497 5.84456 104.497 1 109.994 1C115.494 1 115.494 5.84456 120.99 5.84456C126.491 5.84456 126.491 1 131.991 1C137.491 1 137.491 5.84456 142.991 5.84456C148.491 5.84456 148.491 1 153.992 1C159.492 1 159.492 5.84456 164.988 5.84456C170.489 5.84456 170.489 1 175.985 1C181.486 1 181.486 5.84456 186.986 5.84456C192.486 5.84456 192.486 1 197.986 1C203.486 1 203.486 5.84456 208.987 5.84456C214.487 5.84456 214.487 1 219.987 1C225.487 1 225.487 5.84456 230.987 5.84456C236.488 5.84456 236.488 1 241.988 1C247.488 1 247.488 5.84456 252.988 5.84456C258.488 5.84456 258.488 1 263.989 1C269.489 1 269.489 5.84456 274.989 5.84456C280.489 5.84456 280.489 1 285.99 1C291.49 1 291.49 5.84456 296.99 5.84456C302.49 5.84456 302.49 1 307.99 1C313.491 1 313.491 5.84456 318.991 5.84456C324.491 5.84456 324.491 1 329.991 1C335.491 1 335.491 5.84456 340.992 5.84456C346.492 5.84456 346.492 1 351.992 1C357.492 1 357.492 5.84456 362.996 5.84456C368.5 5.84456 368.496 1 374 1" stroke="#f3f5fe" stroke-width="2" stroke-miterlimit="10"/>
          </pattern>
        </defs>

        <rect fill="url(#squigglePattern)" width="100%" height="100%"/>
      </svg>

      <div class="author">
        <img class='avatar' src="/images/Default-avatar.png" alt="Avatar">
        <h1 class="username"></h1>
        <div class="bio"></div>
      </div>

      <svg class="hr-inline desktop" width="374" height="7" viewBox="0 0 374 7" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0 1C5.50021 1 5.50021 5.84456 11.0004 5.84456C16.5006 5.84456 16.5006 1 22.0008 1C27.501 1 27.501 5.84456 33.0013 5.84456C38.5015 5.84456 38.5015 1 44.0017 1C49.5019 1 49.5019 5.84456 55.0021 5.84456C60.5023 5.84456 60.5023 1 66.0025 1C71.5027 1 71.5027 5.84456 77.0029 5.84456C82.5031 5.84456 82.5031 1 87.9998 1C93.5 1 93.5 5.84456 98.9967 5.84456C104.497 5.84456 104.497 1 109.994 1C115.494 1 115.494 5.84456 120.99 5.84456C126.491 5.84456 126.491 1 131.991 1C137.491 1 137.491 5.84456 142.991 5.84456C148.491 5.84456 148.491 1 153.992 1C159.492 1 159.492 5.84456 164.988 5.84456C170.489 5.84456 170.489 1 175.985 1C181.486 1 181.486 5.84456 186.986 5.84456C192.486 5.84456 192.486 1 197.986 1C203.486 1 203.486 5.84456 208.987 5.84456C214.487 5.84456 214.487 1 219.987 1C225.487 1 225.487 5.84456 230.987 5.84456C236.488 5.84456 236.488 1 241.988 1C247.488 1 247.488 5.84456 252.988 5.84456C258.488 5.84456 258.488 1 263.989 1C269.489 1 269.489 5.84456 274.989 5.84456C280.489 5.84456 280.489 1 285.99 1C291.49 1 291.49 5.84456 296.99 5.84456C302.49 5.84456 302.49 1 307.99 1C313.491 1 313.491 5.84456 318.991 5.84456C324.491 5.84456 324.491 1 329.991 1C335.491 1 335.491 5.84456 340.992 5.84456C346.492 5.84456 346.492 1 351.992 1C357.492 1 357.492 5.84456 362.996 5.84456C368.5 5.84456 368.496 1 374 1" stroke="#f3f5fe" stroke-width="2" stroke-miterlimit="10"/>
      </svg>

      <div class="install-button-wrapper desktop">
        <a class='install-button' href="/beta">
          Waitlist
          <svg class="svg-button" viewBox="0 0 21 22" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1.93892 19.9988L18.9736 2.96362" stroke="black" stroke-width="3.993"/>
          <path d="M19 16.7368L19 2.93875L5.20193 2.93875" stroke="black" stroke-width="3.993"/>
          </svg>
        </a>
      </div>
    </header>

    <div class="posts">
      <footer style="display: none;">
        <a id="load-more">Load more</a>
      </footer>
    </div>
  </div>

<script type="module">
  import { populateVideoGrid, getUserHandleFromURL, getCurrentCursor, initProfile } from '/js/bluesky-profile.js';
  
  // Explicitly initialize profile when this HTML loads
  // This ensures profile loads when navigating back from other pages
  initProfile();
  
  const loadingHTML = '<div class="loading"><p>Fetching videos&hellip;</p></div>';

  async function loadMore() {
    const cursor = getCurrentCursor();
    const footer = document.querySelector('footer');
    const loadMoreBtn = document.getElementById('load-more');
    
    if (!footer || !loadMoreBtn || !cursor) {
      if (footer) footer.style.display = 'none';
      return;
    }

    loadMoreBtn.remove();
    footer.insertAdjacentHTML('beforeend', loadingHTML);

    try {
      const handle = getUserHandleFromURL();
      if (!handle) return;
      
      const nextCursor = await populateVideoGrid(handle, cursor);
      footer.querySelector('.loading')?.remove();
      
      if (nextCursor) {
        footer.style.display = 'flex';
        footer.appendChild(loadMoreBtn);
      } else {
        footer.style.display = 'none';
      }
    } catch (error) {
      console.error('Error loading more posts:', error);
      footer.querySelector('.loading')?.remove();
      footer.style.display = 'flex';
      footer.appendChild(loadMoreBtn);
    }
  }

  document.getElementById('load-more')?.addEventListener('click', (e) => {
    e.preventDefault();
    loadMore();
  });

  // Auto-load more if needed after initial load
  setTimeout(() => {
    if (document.querySelectorAll('.post').length < 6 && getCurrentCursor()) {
      loadMore();
    }
  }, 1000);
</script>

</body>
</html>
