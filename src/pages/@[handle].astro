        </svg>
      </div>

      <div class="install-button-wrapper desktop">
        <a class='install-button' href="/beta" style={`background-color: ${textColor}; color: ${backgroundColor};`}>
          Get the beta
          <svg class="svg-button" viewBox="0 0 21 22" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1.93892 19.9988L18.9736 2.96362" stroke="currentColor" stroke-width="3.993"/>
          <path d="M19 16.7368L19 2.93875L5.20193 2.93875" stroke="currentColor" stroke-width="3.993"/>
          </svg>
