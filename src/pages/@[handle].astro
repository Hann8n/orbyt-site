---
export const prerender = false; // SSR route

import { fetchProfile, fetchVideoPosts, toAbsoluteUrl, getImageMimeType } from '../utils/bluesky-api';
import { getColor } from '../utils/orbyt-api';
import { parseRichText } from '../utils/richtext';
import { ClientRouter } from 'astro:transitions';

const { handle } = Astro.params;

if (!handle) {
  return new Response(null, { status: 404 });
}

// Fetch profile and videos in parallel (both only need handle)
const [profileData, videoFeed] = await Promise.all([
  fetchProfile(handle),
  fetchVideoPosts(handle, undefined, 30),
]);

// Return 404 if profile not found
if (!profileData) {
  return new Response(null, { status: 404 });
}

const videoPosts = videoFeed.posts;
const nextCursor = videoFeed.cursor;

// Fetch profile colors via Service Binding
const { env } = Astro.locals.runtime;
if (!env.ORBYT_API) {
  console.error('ORBYT_API binding not found in env:', Object.keys(env));
}
const colorData = profileData.did && env.ORBYT_API
  ? await getColor(profileData.did, env.ORBYT_API)
  : null;

// Extract metadata with fallbacks
const displayName = profileData?.displayName || handle || 'Profile';
const description = profileData?.description || `Profile page for @${handle}`;
const avatar = profileData?.avatar || '/images/Default-avatar.png';
const ogImage = toAbsoluteUrl(avatar);
const ogUrl = `https://getorbyt.com/@${handle}`;
const ogTitle = `@${handle} on orbyt`;
const ogDescription = description.length > 200 ? description.substring(0, 200) + '...' : description;

// OG image properties
const ogImageWidth = 1200;
const ogImageHeight = 1200;
const ogImageType = getImageMimeType(avatar);
const ogImageAlt = description.length > 200 ? description.substring(0, 200) : description;

// Format join date for beta badge tooltip
const joinDate = colorData?.joinedAt 
  ? new Date(colorData.joinedAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
  : null;

// Color styles
const textColor = colorData?.textColor || '#ccd7e9';
const backgroundColor = colorData?.backgroundColor || '#0e141b';

// Cache at Cloudflare edge: 60s fresh, serve stale up to 5min while revalidating
Astro.response.headers.set('Cache-Control', 'public, s-maxage=60, stale-while-revalidate=300');
---

