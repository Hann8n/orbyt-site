---
const url = Astro.url;

// All users see this landing page with QR code
const appUrl = `${url.origin}/app`;
const qrCodeUrl = `https://api.qrserver.com/v1/create-qr-code/?size=200x200&bgcolor=000000&color=f3f5fe&data=${encodeURIComponent(appUrl)}`;
---
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Get the App - orbyt</title>
    
    <style>
        @font-face {
            font-family: 'Figtree';
            src: url('/fonts/Figtree/Figtree-VariableFont_wght.woff2') format('woff2');
            font-weight: 300 900;
            font-style: normal;
            font-display: fallback;
        }
    </style>
    <link rel="preload" href="/fonts/Figtree/Figtree-VariableFont_wght.woff2" as="font" type="font/woff2" crossorigin>
    
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png">
    <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico">
    
    <style>
        * {
            box-sizing: border-box;
        }
        html, body {
            margin: 0;
            padding: 0;
            height: 100%;
            min-height: 100vh;
        }
        body {
            --bg-color: #000;
            --fg-color: #f3f5fe;
            background: var(--bg-color);
            font-family: 'Figtree', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .container {
            position: relative;
            width: 100%;
            max-width: 800px;
            padding: 20px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
        }
        .logo-icon {
            width: 120px;
            height: auto;
            display: block;
            margin: 0 auto;
        }
        .logo-icon .logo-fg {
            fill: var(--fg-color);
            stroke: var(--fg-color);
        }
        .logo {
            display: block;
            transition: opacity 0.2s ease;
        }
        .logo:hover {
            opacity: 0.8;
        }
        .subtitle {
            font-family: 'Figtree', sans-serif;
            font-weight: 600;
            font-size: 28px;
            color: var(--fg-color);
            text-align: center;
            display: block;
            margin: 20px auto 0;
        }
        .qr-section {
            margin: 40px 0;
            text-align: center;
        }
        .qr-container {
            background: var(--bg-color);
            padding: 20px;
            border-radius: 20px;
            border: 2px solid #333;
            display: inline-block;
        }
        .qr-code {
            width: 200px;
            height: 200px;
            display: block;
        }
        .qr-label {
            font-size: 14px;
            color: #888;
            margin-top: 16px;
            letter-spacing: 0.05em;
        }
        .buttons {
            text-align: center;
            margin-top: 10px;
            width: 100%;
            max-width: 400px;
        }
        .download-button {
            background: #551DEF;
            border: 2px solid #000000;
            border-radius: 30px;
            height: 60px;
            font-weight: bold;
            font-size: 20px;
            line-height: 28px;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            text-decoration: none;
            color: #E0EBFF;
            width: 100%;
            margin: 0 auto 12px auto;
        }
        .download-button:hover {
            opacity: 0.9;
        }
        .separator {
            height: 7px;
            margin-bottom: 20px;
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: flex-start;
            width: 100%;
        }
        .separator svg {
            width: 100%;
            height: 7px;
        }
        .footer {
            display: flex;
            flex-wrap: wrap;
            justify-content: flex-start;
            gap: 12px 32px;
            margin-top: auto;
            margin-bottom: 40px;
        }
        .footer a {
            font-style: normal;
            font-weight: bold;
            font-size: 13px;
            text-align: left;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            text-decoration: none;
            color: #ccc;
        }
        .footer a:hover {
            color: #f3f5fe;
        }
        
        @media (max-width: 500px) {
            .logo-icon {
                width: 90px;
            }
            .subtitle {
                font-size: 22px;
            }
            .qr-section {
                margin: 30px 0;
            }
            .qr-code {
                width: 180px;
                height: 180px;
            }
            .download-button {
                height: 50px;
                font-size: 18px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="main-content">
            <a href="/" class="logo">
                <svg class="logo-icon" xmlns="http://www.w3.org/2000/svg" viewBox="65 65 894 894">
                    <defs>
                        <mask id="cutout-mask">
