        </svg>
      </a>
      <div class="subtitle subtitle-desktop">{t('app.subtitleDesktop')}</div>
      <div class="subtitle subtitle-mobile">{t('app.subtitleMobile')}</div>
      <div class="qr-section">
        <div class="qr-container">
          <img class="qr-code" src={qrCodeUrl} alt={t('app.qrAlt')} />
        </div>
        <div class="qr-label">{t('app.qrLabel')}</div>
      </div>
      <div class="buttons">
        <a href="https://apps.apple.com/us/app/orbyt-video/id6751679299" class="download-button">{t('index.ios')}</a>
        <a href={translatePath('/beta')} class="download-button">{t('index.androidWaitlist')}</a>
      </div>
    </div>
  </div>
</Base>

<style>
  html, body { margin: 0; padding: 0; height: 100%; min-height: 100vh; }
  body { --bg-color: #000; --fg-color: #f3f5fe; background: var(--bg-color); font-family: 'Figtree', sans-serif; display: flex; align-items: center; justify-content: center; }
  .container { width: 100%; max-width: 800px; padding: 20px; min-height: 100vh; display: flex; flex-direction: column; }
  .main-content { flex: 1; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; }
  .logo { display: block; transition: opacity 0.2s ease; }
  .logo:hover { opacity: 0.8; }
  .logo-icon { width: 120px; height: auto; }
  .logo-icon .logo-fg { fill: var(--fg-color); stroke: var(--fg-color); }
  .subtitle { font-weight: 600; font-size: 28px; color: var(--fg-color); margin: 20px auto 0; }
  .subtitle-mobile { display: none; }
  .qr-section { margin: 40px 0; }
  .qr-container { padding: 20px; border-radius: 20px; border: 2px solid #333; display: inline-block; }
  .qr-code { width: 200px; height: 200px; display: block; }
  .qr-label { font-size: 14px; color: #888; margin-top: 16px; }
  .buttons { text-align: center; margin-top: 10px; width: 100%; max-width: 400px; }
  .download-button { background: #551DEF; border: 2px solid #000; border-radius: 30px; height: 60px; font-weight: bold; font-size: 20px; display: flex; align-items: center; justify-content: center; text-decoration: none; color: #E0EBFF; width: 100%; margin: 0 auto 12px auto; }
  @media (hover: none) and (pointer: coarse) { .qr-section { display: none; } .subtitle-desktop { display: none; } .subtitle-mobile { display: block; } .buttons { margin-top: 40px; } }
  @media (max-width: 500px) { .logo-icon { width: 90px; } .subtitle { font-size: 22px; } .qr-code { width: 180px; height: 180px; } .download-button { height: 50px; font-size: 18px; } }
</style>
