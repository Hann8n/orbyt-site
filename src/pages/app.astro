                    <rect fill="url(#squigglePattern)" width="100%" height="100%"/>
                </svg>
            </div>
            <a href="https://bsky.app/profile/getorbyt.com">bluesky</a>
            <a href="https://discord.gg/8gNQPFygnF">discord</a>
            <a href="/terms">terms</a>
            <a href="/privacy">privacy</a>
            <a href="/contact">contact</a>
        </footer>
    </div>
</body>
</html>
