---
export const prerender = true;
---

<!doctype html>
<html lang="en">
<head>
    <meta name="google-site-verification" content="4xaimUg28uLCqKwsPNIz6QeG_tfnLlAdHgS5bC_90JU"/>
    <meta charset="utf-8">
    <title>orbyt - video communities</title>
    <meta name="description" content="a new video app for bluesky">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Critical: Inline font-face for immediate availability (no network delay) -->
    <style>
      @font-face {
        font-family: 'Figtree';
        src: url('/fonts/Figtree/Figtree-VariableFont_wght.woff2') format('woff2');
        font-weight: 300 900;
        font-style: normal;
        font-display: fallback; /* Short block window, then swap - prevents FOUT for logo */
      }
    </style>
    <!-- Preload Figtree font to start download early -->
    <link rel="preload" href="/fonts/Figtree/Figtree-VariableFont_wght.woff2" as="font" type="font/woff2" crossorigin>

    <meta property="og:title" content="orbyt - video communities"/>
    <meta property="og:description" content="a new video app for bluesky"/>
    <meta property="og:type" content="website"/>
    <meta property="og:url" content="https://getorbyt.com/"/>
    <meta property="og:image" content="https://getorbyt.com/images/orbyt-logotype.png"/>
    <meta property="og:image:type" content="image/png"/>

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image"/>
    <meta name="twitter:title" content="orbyt - video communities"/>
    <meta name="twitter:description" content="a new video app for bluesky"/>
    <meta name="twitter:image" content="https://getorbyt.com/images/orbyt-logotype.png"/>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/normalize/8.0.1/normalize.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/skeleton/2.0.4/skeleton.min.css">

    <!-- Favicon setup -->
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png">
    <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png">
    <link rel="manifest" href="/favicon/site.webmanifest">

    <style>
    a:hover {
        color: #f3f5fe;
    }

    html, body {
        margin: 0;
        padding: 0;
        height: 100%;
        min-height: 100vh;
    }

    body {
        --bg-color: #000;
        --fg-color: #f3f5fe;
        background: var(--bg-color);
        font-family: 'Figtree', sans-serif;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .container {
        position: relative;
        width: 100%;
        max-width: 800px;
        padding: 20px;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    .main-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .download-button {
        background: #551DEF;
        border: 2px solid #000000;
        border-radius: 30px;
        height: 60px;
        font-weight: bold;
        font-size: 23px;
        line-height: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        text-decoration: none;
        color: #E0EBFF;
        max-width: 500px;
        margin: 0 auto 10px auto;
    }

    .row.first {
        margin-top: 0;
        margin-bottom: 0;
    }

    .row.buttons {
        text-align: center;
        margin-top: 40px;
    }

    .logo {
        text-align: center;
    }

    .logo-icon {
        width: 160px;
        height: auto;
        display: block;
        margin: 0 auto 0px auto;
        color: var(--fg-color);
    }

    .logo-icon .logo-bg {
        fill: var(--bg-color);
    }

    .logo-icon .logo-fg {
        fill: var(--fg-color);
        stroke: var(--fg-color);
    }

    .logo-icon .logo-outline {
        fill: none;
    }

    .logo-text {
        font-family: 'Figtree', sans-serif;
        font-weight: 900;
        font-size: 48px;
        color: var(--fg-color);
        text-align: center;
        text-box-trim: trim-start;
        text-box-edge: cap alphabetic;
        display: block;
        margin: 0 auto;
    }

    .motto {
        margin-top: 10px;
        margin-bottom: 0;
    }

    .motto div {
        text-align: center;
    }

    .motto-text {
        font-family: 'Figtree', sans-serif;
        font-weight: 500;
        font-size: 28px;
        color: #01f5b3;
        text-align: center;
        display: block;
        margin: 20px auto;
        letter-spacing: -0.02em;
    }

    .separator {
        height: 7px;
        margin-bottom: 20px;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: flex-start;
        width: 100%;
    }

    .separator svg {
        width: 100%;
        height: 7px;
    }

    .footer {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-start;
        gap: 12px 32px;
        margin-top: auto;
        margin-bottom: 40px;
    }

    .footer a {
        font-style: normal;
        font-weight: bold;
        font-size: 13px;
        text-align: left;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        text-decoration: none;
        color: #ccc;
    }

    .footer a:hover {
        color: #f3f5fe;
    }

    @media (max-width: 500px) {
        .row.first {
            margin-top: 0;
        }

        body {
            background: #000;
        }

        .motto {
            margin-top: 10px;
            margin-bottom: 0;
        }

        .motto-text {
            font-size: 22px;
        }

        .row.buttons {
            margin-top: 30px;
        }

        .logo-icon {
            width: 115px;
            height: auto;
        }

        .logo-text {
            font-size: 36px;
        }

        .download-button {
            height: 50px;
            font-size: 20px;
            margin-bottom: 15px;
        }

    }

    @media (min-width: 1500px) {
        body {
            background-position-y: -100px;
        }
    }

    @media (min-width: 1800px) {
        body {
            background-position-y: -200px;
        }
    }
    </style>
</head>

