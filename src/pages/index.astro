---
export const prerender = true;

import Base from '../layouts/Base.astro';
import IndexContent from '../components/pages/IndexContent.astro';
import { useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<Base
  lang={lang}
  title={t('index.title')}
  description={t('index.metaDescription')}
  canonicalUrl="https://getorbyt.com/"
>
  <Fragment slot="head">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/normalize/8.0.1/normalize.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/skeleton/2.0.4/skeleton.min.css" />
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "orbyt",
      "url": "https://getorbyt.com",
      "logo": "https://getorbyt.com/images/orbyt-logotype.png",
      "description": t('index.metaDescription'),
      "sameAs": ["https://bsky.app/profile/getorbyt.com", "https://community.getorbyt.com"]
    })} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "orbyt",
      "url": "https://getorbyt.com",
      "description": t('index.metaDescription'),
      "potentialAction": {
        "@type": "SearchAction",
        "target": { "@type": "EntryPoint", "urlTemplate": "https://getorbyt.com/@{search_term_string}" },
        "query-input": "required name=search_term_string"
      }
    })} />
  </Fragment>

  <div class="container">
    <div class="main-content">
      <IndexContent t={t} translatePath={translatePath} />
    </div>
  </div>
</Base>

<style>
  a:hover { color: #f3f5fe; }
  html, body { margin: 0; padding: 0; height: 100%; min-height: 100vh; }
  body { --bg-color: #000; --fg-color: #f3f5fe; background: var(--bg-color); font-family: 'Figtree', sans-serif; display: flex; align-items: center; justify-content: center; }
  .container { position: relative; width: 100%; max-width: 800px; padding: 20px; min-height: 100vh; display: flex; flex-direction: column; }
  .main-content { flex: 1; display: flex; flex-direction: column; justify-content: center; }
  .row.first { margin-top: 0; margin-bottom: 0; }
  .logo { text-align: center; }
  .logo-icon { width: 160px; height: auto; display: block; margin: 0 auto; color: var(--fg-color); }
  .logo-icon .logo-bg { fill: var(--bg-color); }
  .logo-icon .logo-fg { fill: var(--fg-color); stroke: var(--fg-color); }
  .logo-text { font-family: 'Figtree', sans-serif; font-weight: 900; font-size: 48px; color: var(--fg-color); text-align: center; display: block; margin: 0 auto; }
  .motto { margin-top: 10px; margin-bottom: 0; }
  .motto div { text-align: center; }
  .motto-text { font-family: 'Figtree', sans-serif; font-weight: 500; font-size: 28px; color: #01f5b3; text-align: center; display: block; margin: 20px auto; }
  .row.buttons { text-align: center; margin-top: 40px; }
  .download-button { background: #551DEF; border: 2px solid #000; border-radius: 30px; height: 60px; font-weight: bold; font-size: 23px; display: flex; align-items: center; justify-content: center; text-decoration: none; color: #E0EBFF; max-width: 500px; margin: 0 auto 10px auto; }
  @media (max-width: 500px) {
    .motto-text { font-size: 22px; }
    .logo-icon { width: 115px; }
    .logo-text { font-size: 36px; }
    .download-button { height: 50px; font-size: 20px; margin-bottom: 15px; }
  }
</style>
