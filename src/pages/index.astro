---
export const prerender = false;

import AltstorePalPeek from '../components/AltstorePalPeek.astro';
import DocumentColorScheme from '../components/DocumentColorScheme.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SkipToContent from '../components/SkipToContent.astro';
import {
	getIosDownloadOptionsFromRequest,
	iosDownloadHrefFromOptions,
} from '../utils/ios-distribution';
import { SITE_DOCUMENT } from '../utils/site-document-theme';
import { useTranslations, hreflangLinks, localeToHtmlLang } from '../i18n/utils';

const locale = Astro.locals.locale ?? 'en';
const countryCode = Astro.locals.countryCode;
const t = useTranslations(locale);
const iosDownload = getIosDownloadOptionsFromRequest(Astro.request);
const iosHref = iosDownloadHrefFromOptions(iosDownload);
const showAltstorePalPeek = iosDownload.primary === 'altstore';
---

<!doctype html>
<html lang={localeToHtmlLang(locale)} class="orbyt-doc-dark">
<head>
    <meta charset="utf-8">
    <DocumentColorScheme
      colorScheme="dark"
      themeColor={SITE_DOCUMENT.orbytBlack}
      tileColor={SITE_DOCUMENT.orbytBlack}
    />
    <link rel="stylesheet" href="/css/tokens.css" />
    <link rel="stylesheet" href="/css/site-footer.css" />
    <link rel="stylesheet" href="/css/site-document.css" />
    <link rel="stylesheet" href="/css/caveat.css" />
    <link rel="stylesheet" href="/css/klee-one.css" />
    <meta name="google-site-verification" content="4xaimUg28uLCqKwsPNIz6QeG_tfnLlAdHgS5bC_90JU"/>
    {hreflangLinks('/').map(({ hreflang, href }) => (
      <link rel="alternate" hreflang={hreflang} href={href} />
    ))}
    <title>{t('index.title')}</title>
    <meta name="description" content={t('index.meta.description')}>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link rel="preload" href="/fonts/Figtree/Figtree-VariableFont_wght.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/Caveat/Caveat-latin-400.woff2" as="font" type="font/woff2" crossorigin>

    <meta property="og:title" content={t('index.title')}/>
    <meta property="og:description" content={t('index.meta.description')}/>
    <meta property="og:type" content="website"/>
    <meta property="og:url" content="https://getorbyt.com/"/>
    <meta property="og:image" content="https://getorbyt.com/images/orbyt-logotype.png"/>
    <meta property="og:image:type" content="image/png"/>

    <meta name="twitter:card" content="summary_large_image"/>
    <meta name="twitter:title" content={t('index.title')}/>
    <meta name="twitter:description" content={t('index.meta.description')}/>
    <meta name="twitter:image" content="https://getorbyt.com/images/orbyt-logotype.png"/>

    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "orbyt",
      "url": "https://getorbyt.com",
      "logo": "https://getorbyt.com/images/orbyt-logotype.png",
      "description": "a new video app for bluesky",
      "sameAs": [
        "https://bsky.app/profile/getorbyt.com",
        "https://community.getorbyt.com"
      ]
    }
    </script>
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "orbyt",
      "url": "https://getorbyt.com",
      "description": "a new video app for bluesky",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://getorbyt.com/@{search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    }
    </script>

    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png">
    <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png">
    <link rel="manifest" href="/favicon/site.webmanifest">

    <style>
    a:hover {
        color: #f3f5fe;
    }

    .site-doc--landing {
        --bg-color: var(--orbyt-page-bg);
        --fg-color: var(--orbyt-white);
        /* Tight stack: mark / wordmark / slogan */
        --landing-logo-icon-wordmark-gap: clamp(4px, 1.2vw, 10px);
        --landing-wordmark-slogan-gap: clamp(6px, 1.6vw, 14px);
        /* Breathing room before CTAs */
        --landing-hero-actions-gap: clamp(40px, 12vw, 96px);
    }

    /* Hero column — constrains content to a readable width on all screen sizes */
    .hero-column {
        width: 100%;
        max-width: 420px;
    }

    .download-button-wrap {
        position: relative;
        margin: 0 0 10px 0;
        overflow: visible;
    }

    .download-button-wrap .download-button {
        position: relative;
        z-index: 1;
        margin: 0;
        max-width: none;
        width: 100%;
    }

    .download-button {
        background: #551DEF;
        border: 2px solid #000000;
        border-radius: 30px;
        min-height: 56px;
        padding: 0.75rem 1.5rem;
        font-weight: bold;
        font-size: 19px;
        line-height: 1.2;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        text-decoration: none;
        color: #E0EBFF;
        width: 100%;
        margin: 0 0 10px 0;
    }

    .home-hero {
        margin-top: 0;
        margin-bottom: 0;
    }

    .home-actions {
        text-align: center;
        margin-top: var(--landing-hero-actions-gap);
    }

    .logo {
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--landing-logo-icon-wordmark-gap);
    }

    .logo-icon {
        width: 110px;
        height: auto;
        display: block;
        margin: 0;
        color: var(--fg-color);
    }

    .logo-icon .logo-bg {
        fill: var(--bg-color);
    }

    .logo-icon .logo-fg {
        fill: var(--fg-color);
        stroke: var(--fg-color);
    }

    .logo-icon .logo-outline {
        fill: none;
    }

    .logo-text {
        font-family: 'Figtree', sans-serif;
        font-weight: 900;
        font-size: 42px;
        color: var(--fg-color);
        text-align: center;
        text-box-trim: trim-start;
        text-box-edge: cap alphabetic;
        display: block;
        margin: 0 auto;
    }

    .home-motto {
        margin-top: var(--landing-wordmark-slogan-gap);
        margin-bottom: 0;
        text-align: center;
    }

    .motto-text {
        font-family: 'Figtree', sans-serif;
        font-weight: 500;
        font-size: 20px;
        color: #01f5b3;
        text-align: center;
        display: block;
        margin: 0 auto;
        letter-spacing: -0.02em;
    }

    @media (max-width: 360px) {
        .logo-icon { width: 88px; }
        .logo-text { font-size: 34px; }
        .motto-text { font-size: 17px; }
        .download-button { font-size: 17px; min-height: 50px; }
    }
    </style>
</head>

<body>
    <SkipToContent />
    <div class="site-doc site-doc--landing">
        <main id="main-content" class="main-content">
            <div class="hero-column">
            <div class="home-hero">
                <div class="logo">
                    <svg class="logo-icon" xmlns="http://www.w3.org/2000/svg" viewBox="65 65 894 894">
                        <defs>
                            <mask id="cutout-mask">
                                <rect x="65" y="65" width="894" height="894" fill="white"/>
                                <path fill="black" fill-rule="evenodd" d="M349 129.3c-23.9 5.4-36.8 31.5-26.1 53.2 8 16.2 25.2 24.4 42.1 20.1 7.4-1.9 5.3-3.4 18.5 13.9 10.3 13.6 33.6 44.2 36.7 48.4 3.5 4.6 3.5 4.6-1.1 8.9-5.9 5.6-14.1 16.9-19 26-5 9.4-3.4 8.6-22.1 10.2-136.2 11.1-177 34.7-192.6 111.5-16.5 81.2-16.5 193.6.1 276.7 10.5 52.9 39.8 83.7 89.3 93.9 6 1.3 6 1.3 2.5 8.8-18.4 39.4-5.4 73.1 30 78.1 24.5 3.5 32.3-1.8 73.7-50 20.8-24.3 16.8-22.1 37-20.5 50.9 4.1 138.2 4.1 189 0 20.2-1.6 16.2-3.8 37 20.5 41.4 48.2 49.2 53.5 73.7 50 35.4-5 48.4-38.7 30-78.1-3.5-7.5-3.5-7.5 2.5-8.8 49.5-10.2 78.8-41 89.3-93.9 16.6-83.1 16.6-195.5.1-276.7C824 344.7 783.2 321.1 647 310c-18.7-1.6-17.1-.8-22.1-10.2-4.9-9.1-13.1-20.4-19-26-4.6-4.3-4.6-4.3-1.1-8.9 3.1-4.2 26.4-34.8 36.7-48.4 13.2-17.3 11.1-15.8 18.5-13.9 41.5 10.6 64.2-49.2 26.3-69.3-32-17.1-68 17.2-51.7 49.3 3.1 6.1 3.1 6.1-11.8 25.5-8.2 10.7-20 26-26.1 34.1-11.1 14.8-11.1 14.8-14.7 12.6-44.5-26.5-94.5-26.5-139 0-3.6 2.2-3.6 2.2-14.7-12.6-6.1-8.1-17.9-23.4-26.1-34.1-14.9-19.4-14.9-19.4-11.8-25.5 13.8-27.1-11.7-59.8-41.4-53.3m249.3 243.2C752 381.3 773.8 399.3 781.1 523c5.8 98.9-9.4 168.3-41.5 189.8-59.5 39.8-394.7 39.8-454.2 0-32.1-21.5-47.3-90.9-41.5-189.8 7.7-130.5 28.8-144.8 226.1-152.4 19.3-.8 104.3.5 128.3 1.9Z"/>
                                <rect fill="black" x="372" y="482" width="82" height="136" rx="41" ry="41"/>
                                <rect fill="black" x="570" y="482" width="82" height="136" rx="41" ry="41"/>
                            </mask>
                        </defs>
                        <path class="logo-fg" mask="url(#cutout-mask)" stroke-width="65" stroke-linejoin="round" stroke-linecap="round" d="M349 129.3c-23.9 5.4-36.8 31.5-26.1 53.2 8 16.2 25.2 24.4 42.1 20.1 7.4-1.9 5.3-3.4 18.5 13.9 10.3 13.6 33.6 44.2 36.7 48.4 3.5 4.6 3.5 4.6-1.1 8.9-5.9 5.6-14.1 16.9-19 26-5 9.4-3.4 8.6-22.1 10.2-136.2 11.1-177 34.7-192.6 111.5-16.5 81.2-16.5 193.6.1 276.7 10.5 52.9 39.8 83.7 89.3 93.9 6 1.3 6 1.3 2.5 8.8-18.4 39.4-5.4 73.1 30 78.1 24.5 3.5 32.3-1.8 73.7-50 20.8-24.3 16.8-22.1 37-20.5 50.9 4.1 138.2 4.1 189 0 20.2-1.6 16.2-3.8 37 20.5 41.4 48.2 49.2 53.5 73.7 50 35.4-5 48.4-38.7 30-78.1-3.5-7.5-3.5-7.5 2.5-8.8 49.5-10.2 78.8-41 89.3-93.9 16.6-83.1 16.6-195.5.1-276.7C824 344.7 783.2 321.1 647 310c-18.7-1.6-17.1-.8-22.1-10.2-4.9-9.1-13.1-20.4-19-26-4.6-4.3-4.6-4.3-1.1-8.9 3.1-4.2 26.4-34.8 36.7-48.4 13.2-17.3 11.1-15.8 18.5-13.9 41.5 10.6 64.2-49.2 26.3-69.3-32-17.1-68 17.2-51.7 49.3 3.1 6.1 3.1 6.1-11.8 25.5-8.2 10.7-20 26-26.1 34.1-11.1 14.8-11.1 14.8-14.7 12.6-44.5-26.5-94.5-26.5-139 0-3.6 2.2-3.6 2.2-14.7-12.6-6.1-8.1-17.9-23.4-26.1-34.1-14.9-19.4-14.9-19.4-11.8-25.5 13.8-27.1-11.7-59.8-41.4-53.3Z"/>
                    </svg>
                    <div class="logo-text">orbyt</div>
                </div>
            </div>
            <div class="home-motto">
                <p class="motto-text">{t('index.motto')}</p>
            </div>
            <div class="home-actions">
                <div
                    class:list={[
                        'download-button-wrap',
                        { 'download-button-wrap--pal': showAltstorePalPeek },
                    ]}
                >
                    {showAltstorePalPeek && <AltstorePalPeek href={iosHref} locale={locale} />}
                    <a href="/ios" class="download-button">{t('index.button.ios')}</a>
                </div>
                <a href="/android" class="download-button">{t('index.button.android_waitlist')}</a>
            </div>
            </div>
        </main>

        <SiteFooter locale={locale} currentPath="/" countryCode={countryCode} />
    </div>
</body>
</html>