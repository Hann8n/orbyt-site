---
import Footer from '../components/Footer.astro';
import { getLangFromUrl, useTranslatedPath } from '../i18n/utils';
import { nonDefaultLocales } from '../i18n/ui';

interface Props {
  lang: string;
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  noFooter?: boolean;
}

const { lang, title, description, canonicalUrl, ogImage = 'https://getorbyt.com/images/orbyt-logotype.png', noFooter = false } = Astro.props;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://getorbyt.com';
const currentLang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(currentLang as import('../i18n/ui').defaultLang);

function getCurrentRoute(pathname: string, locale: string): string {
  const localePrefix = `/${locale}`;
  if (pathname === localePrefix || pathname.startsWith(`${localePrefix}/`)) {
    return pathname.slice(localePrefix.length) || '/';
  }
  return pathname || '/';
}
const currentRoute = getCurrentRoute(Astro.url.pathname, currentLang);
const url = canonicalUrl || `${siteUrl}${Astro.url.pathname}`;
const defaultLocaleUrl = `${siteUrl}${translatePath(currentRoute, 'en')}`;
---

<!doctype html>
<html lang={lang}>
<head>
  <meta name="google-site-verification" content="4xaimUg28uLCqKwsPNIz6QeG_tfnLlAdHgS5bC_90JU"/>
  <meta charset="utf-8">
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <style is:global>
    @font-face {
      font-family: 'Figtree';
      src: url('/fonts/Figtree/Figtree-VariableFont_wght.woff2') format('woff2');
      font-weight: 300 900;
      font-style: normal;
      font-display: fallback;
    }
  </style>
  <link rel="preload" href="/fonts/Figtree/Figtree-VariableFont_wght.woff2" as="font" type="font/woff2" crossorigin>

  <meta property="og:title" content={title} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:type" content="website" />
  <meta property="og:url" content={url} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:type" content="image/png" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  {description && <meta name="twitter:description" content={description} />}
  <meta name="twitter:image" content={ogImage} />

  <!-- hreflang -->
  <link rel="alternate" hreflang="x-default" href={defaultLocaleUrl} />
  <link rel="alternate" hreflang="en" href={defaultLocaleUrl} />
  {nonDefaultLocales.map((l) => {
    const localizedUrl = `${siteUrl}${translatePath(currentRoute, l)}`;
    return <link rel="alternate" hreflang={l} href={localizedUrl} />;
  })}

  <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png">
  <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png">
  <link rel="manifest" href="/favicon/site.webmanifest">

  <slot name="head" />
</head>
<body>
  <slot />

  {!noFooter && <Footer lang={lang} />}
</body>
</html>
